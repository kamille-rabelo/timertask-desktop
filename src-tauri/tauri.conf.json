{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "timertasks",
  "version": "0.1.0",
  "identifier": "com.fael.timertasks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Timertasks",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/favicon-32.png",
      "icons/favicon-128.png",
      "icons/favicon-128.png",
      "icons/app.icns",
      "icons/app.ico"
    ]
  }
}
